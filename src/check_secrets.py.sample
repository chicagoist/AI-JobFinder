#!/usr/bin/env python3
import sys
if sys.platform.startswith("win"):
    sys.stdout.reconfigure(encoding="utf-8", errors="replace")
    sys.stderr.reconfigure(encoding="utf-8", errors="replace")
"""
check_secrets.py — Personal data / secrets scanner for Gemini-JobAgent.

Usage (manual):
    python check_secrets.py                     # Scan all staged files (pre-commit mode)
    python check_secrets.py --all               # Scan entire working tree
    python check_secrets.py --file path/to/file # Scan a single file
    python check_secrets.py --fix-gitignore     # Auto-add missing entries to .gitignore

Exit code:
    0  — No secrets found (safe to commit)
    1  — Secrets found (commit BLOCKED)

This script is called automatically by the git pre-commit hook (.git/hooks/pre-commit).
To install the hook, run:  python check_secrets.py --install-hook
"""

import os
import re
import subprocess
import argparse

# ============================================================
# PERSONAL DATA PATTERNS
# ⚠️ EDIT THIS SECTION: Replace the placeholder names below
# with YOUR actual surname, first name, and email fragments.
# ============================================================

# Names and personal identifiers
PERSONAL_NAMES = [
    "YourSurname",
    "YourFirstname",
    "YourCyrillicSurname",   # e.g. Иванов
    "YourCyrillicFirstname", # e.g. Иван
]

# Filenames containing personal data (regex patterns)
PERSONAL_FILENAMES = [
    r"Lebenslauf_YourSurname",
    r"Anschreiben_YourSurname",
    r"CV_YourSurname",
    r"yourfirstname",
]

# Personal email addresses (exact strings, case-insensitive)
PERSONAL_EMAILS = [
    "yoursurname",
    "your.alias",
]

# Real API key patterns (structure only — no real keys stored here)
API_KEY_PATTERNS = [
    # Google API key: AIzaSy + 33 chars of [A-Za-z0-9_-]
    (r"AIzaSy[A-Za-z0-9_\-]{33}", "Google API key"),
    # Generic 40-char hex key (GitHub tokens, etc.)
    (r"(?<![A-Za-z0-9])[A-Fa-f0-9]{40}(?![A-Za-z0-9])", "40-char hex token"),
    # OpenAI key
    (r"sk-[A-Za-z0-9]{48}", "OpenAI API key"),
    # Generic Bearer token-like patterns (long base64 strings not in sample files)
    (r"Bearer\s+[A-Za-z0-9\+\/=]{30,}", "Bearer token"),
]

# Password patterns (look for assignments with real-looking passwords)
PASSWORD_PATTERNS = [
    # YAML/JSON password fields with real values (not placeholders like <...>)
    (r"password\s*:\s*[\"']?(?!<|YOUR_|PLACEHOLDER|app_password|xxxx)[A-Za-z0-9@#$%^&*!]{6,}",
     "YAML password field"),
    # Google App Password format: exactly 4 groups of 4 lowercase letters in a quoted value or at line end
    # Only match when preceded by : or " or ' (value context), not normal prose
    (r"(?::\s*[\"']|[\"'])\s*[a-z]{4}\s[a-z]{4}\s[a-z]{4}\s[a-z]{4}\s*[\"']?",
     "Google App Password"),
    # SMTP password in any form (with real value, not placeholder)
    (r"smtp.*password.*[\"'][^\"'<>]{6,}[\"']", "SMTP password"),
]

# Real API keys to flag (placeholders are safe)
PLACEHOLDER_PATTERNS = [
    "<YOUR_GEMINI_API_KEY",
    "YOUR_KEY_",
    "<Username>",
    "<YourUser>",
    "<YOUR_EMAIL>",
    "<Vorname>",
    "<Nachname>",
    "candidate.email@example.com",
    "your.email@gmail.com",
    "candidate@gmail.com",
    "xxxx xxxx xxxx xxxx",
    "app_password_here",
    "<YOUR_SMTP_PASSWORD",
    "YOUR_SMTP_PASSWORD",
    "<YOUR_",
]

# File extensions to skip (binary files, non-text)
SKIP_EXTENSIONS = {
    ".pdf", ".png", ".jpg", ".jpeg", ".gif", ".bmp", ".ico",
    ".db", ".sqlite", ".exe", ".dll", ".so", ".pyc", ".pyo",
    ".zip", ".tar", ".gz", ".7z", ".rar",
    ".woff", ".woff2", ".ttf", ".eot",
    ".mp4", ".mp3", ".avi",
}

# Files/patterns where password scanning may produce false positives
SKIP_PASSWORD_SCAN = {
    "agent.py",                  # Contains smtp_section.get("password", "") — config reader, not real password
}

# Files/patterns to always skip (relative paths or basenames)
SKIP_FILES = {
    "check_secrets.py",          # This file itself — contains patterns as strings
    "check_secrets.py.bak",
}

# Directories to always skip
SKIP_DIRS = {
    ".git", "__pycache__", "node_modules", ".venv", "venv",
    ".mypy_cache", ".pytest_cache",
}

# ============================================================
# COLORS
# ============================================================

class C:
    RED    = "\033[91m"
    YELLOW = "\033[93m"
    GREEN  = "\033[92m"
    CYAN   = "\033[96m"
    BOLD   = "\033[1m"
    END    = "\033[0m"

# ============================================================
# CORE SCANNING LOGIC
# ============================================================

def is_placeholder(value: str) -> bool:
    """Return True if the matched string looks like a placeholder, not a real secret."""
    v = value.strip()
    for ph in PLACEHOLDER_PATTERNS:
        if ph.lower() in v.lower():
            return True
    # Angle-bracket placeholders like <YOUR_API_KEY>
    if re.search(r"<[^>]{3,}>", v):
        return True
    return False


def scan_content(content: str, filepath: str) -> list[dict]:
    """
    Scan text content for personal data / secrets.
    Returns list of findings: [{line_no, pattern_name, matched_text, line_content}]
    """
    findings = []
    lines = content.splitlines()

    for line_no, line in enumerate(lines, start=1):
        line_stripped = line.strip()
        if not line_stripped or line_stripped.startswith("#"):
            continue  # skip blank lines and pure comment lines

        # --- 1. Personal names ---
        for name in PERSONAL_NAMES:
            if re.search(re.escape(name), line, re.IGNORECASE):
                # Allow in .sample files (expected placeholders)
                if filepath.endswith(".sample"):
                    continue
                # Allow in .md documentation files if clearly generic/documented
                # (names in doc files are expected — skip for .md)
                if filepath.endswith(".md"):
                    continue
                findings.append({
                    "line_no": line_no,
                    "pattern": f"Personal name: '{name}'",
                    "matched": name,
                    "line": line.rstrip()
                })

        # --- 2. Personal filenames ---
        for pat in PERSONAL_FILENAMES:
            m = re.search(pat, line, re.IGNORECASE)
            if m and not is_placeholder(m.group(0)):
                if filepath.endswith(".md"):
                    continue
                findings.append({
                    "line_no": line_no,
                    "pattern": f"Personal filename pattern: '{pat}'",
                    "matched": m.group(0),
                    "line": line.rstrip()
                })

        # --- 3. Personal emails ---
        for email_frag in PERSONAL_EMAILS:
            if re.search(re.escape(email_frag), line, re.IGNORECASE):
                if filepath.endswith(".sample") or filepath.endswith(".md"):
                    continue
                findings.append({
                    "line_no": line_no,
                    "pattern": f"Personal email fragment: '{email_frag}'",
                    "matched": email_frag,
                    "line": line.rstrip()
                })

        # --- 4. API key patterns ---
        for pattern, name in API_KEY_PATTERNS:
            m = re.search(pattern, line)
            if m and not is_placeholder(m.group(0)):
                findings.append({
                    "line_no": line_no,
                    "pattern": f"Potential {name}",
                    "matched": m.group(0)[:20] + "...",
                    "line": line.rstrip()
                })

        # --- 5. Password patterns (skip known false-positive files) ---
        skip_passwords = any(filepath.endswith(f) for f in SKIP_PASSWORD_SCAN)
        if not skip_passwords:
            for pattern, name in PASSWORD_PATTERNS:
                m = re.search(pattern, line, re.IGNORECASE)
                if m and not is_placeholder(m.group(0)):
                    findings.append({
                        "line_no": line_no,
                        "pattern": f"Potential {name}",
                        "matched": m.group(0)[:30] + "...",
                        "line": line.rstrip()
                    })

    return findings


def get_staged_files() -> list[str]:
    """Get list of files staged for commit (via git diff --cached --name-only)."""
    try:
        result = subprocess.run(
            ["git", "diff", "--cached", "--name-only", "--diff-filter=ACM"],
            capture_output=True, text=True, check=True
        )
        files = [f.strip() for f in result.stdout.splitlines() if f.strip()]
        return files
    except subprocess.CalledProcessError:
        return []


def get_staged_file_content(filepath: str) -> str | None:
    """Get the staged (index) content of a file — NOT the working tree version."""
    try:
        result = subprocess.run(
            ["git", "show", f":{filepath}"],
            capture_output=True, check=True
        )
        return result.stdout.decode("utf-8", errors="replace")
    except (subprocess.CalledProcessError, UnicodeDecodeError):
        return None


def get_all_tracked_files(root: str = ".") -> list[str]:
    """Get all git-tracked files (for --all mode). Uses 'git ls-files' to respect .gitignore."""
    try:
        result = subprocess.run(
            ["git", "ls-files"],
            capture_output=True, text=True, check=True, cwd=root
        )
        files = [f.strip().replace("\\", "/") for f in result.stdout.splitlines() if f.strip()]
        return files
    except subprocess.CalledProcessError:
        # Fallback: walk but prune directories properly
        tracked = []
        for dirpath, dirnames, filenames in os.walk(root):
            dirnames[:] = [d for d in dirnames if d not in SKIP_DIRS]
            for filename in filenames:
                rel_path = os.path.relpath(os.path.join(dirpath, filename), root)
                tracked.append(rel_path.replace("\\", "/"))
        return tracked


def is_likely_binary(filepath: str) -> bool:
    """Check if a file is likely binary by reading its first 1024 bytes."""
    try:
        with open(filepath, "rb") as f:
            chunk = f.read(1024)
        # If > 10% null bytes or many non-printable chars, assume binary
        null_count = chunk.count(b"\x00")
        if null_count > len(chunk) * 0.1:
            return True
        return False
    except (OSError, IOError):
        return True  # Treat unreadable files as binary (skip them)


def should_skip_file(filepath: str) -> bool:
    """Return True if this file should be skipped entirely."""
    basename = os.path.basename(filepath)
    if basename in SKIP_FILES:
        return True
    _, ext = os.path.splitext(filepath)
    if ext.lower() in SKIP_EXTENSIONS:
        return True
    return False


def scan_file(filepath: str, staged_mode: bool = True) -> list[dict]:
    """
    Scan one file and return findings.
    staged_mode=True  → read from git index (staged content)
    staged_mode=False → read from disk
    """
    if should_skip_file(filepath):
        return []

    if staged_mode:
        content = get_staged_file_content(filepath)
    else:
        # Binary check before reading disk file
        if is_likely_binary(filepath):
            return []
        try:
            with open(filepath, encoding="utf-8", errors="replace") as f:
                content = f.read()
        except (OSError, IOError):
            return []

    if content is None:
        return []

    findings = scan_content(content, filepath)
    return findings


# ============================================================
# REPORTING
# ============================================================

def print_findings(filepath: str, findings: list[dict]):
    print(f"\n{C.RED}{C.BOLD}  ✗ {filepath}{C.END}")
    for f in findings:
        print(f"    {C.YELLOW}Line {f['line_no']:4d}{C.END}  [{C.CYAN}{f['pattern']}{C.END}]")
        print(f"           {f['line'][:120]}")


def run_scan(files: list[str], staged_mode: bool = True) -> int:
    """
    Run the scan. Returns number of files with findings (0 = clean).
    """
    total_findings = 0
    dirty_files = 0

    print(f"\n{C.BOLD}[SCAN] Scanning {'staged' if staged_mode else 'all'} files for personal data / secrets...{C.END}")
    print(f"   Files to scan: {len(files)}")

    for filepath in files:
        findings = scan_file(filepath, staged_mode=staged_mode)
        if findings:
            dirty_files += 1
            total_findings += len(findings)
            print_findings(filepath, findings)

    print()
    if total_findings == 0:
        print(f"{C.GREEN}{C.BOLD}[OK] Clean! No personal data or secrets found. Safe to commit.{C.END}\n")
        return 0
    else:
        print(f"{C.RED}{C.BOLD}[BLOCKED] {total_findings} finding(s) in {dirty_files} file(s).{C.END}")
        print(f"{C.YELLOW}  Fix the issues above before committing.{C.END}")
        print(f"{C.YELLOW}  If a match is a false positive, add it to SKIP_FILES or is_placeholder() in check_secrets.py{C.END}\n")
        return 1


# ============================================================
# GIT HOOK INSTALLATION
# ============================================================

HOOK_SCRIPT = """\
#!/bin/sh
# Auto-generated pre-commit hook by check_secrets.py
# Blocks commits that contain personal data, API keys, or passwords.
python "$(git rev-parse --show-toplevel)/check_secrets.py"
exit $?
"""

def install_hook():
    """Install the pre-commit hook into .git/hooks/."""
    try:
        git_root = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, check=True
        ).stdout.strip()
    except subprocess.CalledProcessError:
        print(f"{C.RED}Not inside a git repository.{C.END}")
        return False

    hooks_dir = os.path.join(git_root, ".git", "hooks")
    hook_path = os.path.join(hooks_dir, "pre-commit")

    os.makedirs(hooks_dir, exist_ok=True)

    if os.path.exists(hook_path):
        print(f"{C.YELLOW}Pre-commit hook already exists at {hook_path}{C.END}")
        overwrite = input("Overwrite? [y/N]: ").strip().lower()
        if overwrite != "y":
            print("Skipped.")
            return False

    with open(hook_path, "w", newline="\n") as f:
        f.write(HOOK_SCRIPT)

    # Make executable (Linux/macOS — no-op on Windows but harmless)
    try:
        os.chmod(hook_path, 0o755)
    except Exception:
        pass

    print(f"{C.GREEN}[OK] Pre-commit hook installed at: {hook_path}{C.END}")
    print(f"  Every 'git commit' will now automatically scan staged files.")
    return True


# ============================================================
# GITIGNORE CHECK
# ============================================================

REQUIRED_GITIGNORE_ENTRIES = [
    "config.yaml",
    "candidate_profile.json",
    "*.pdf",
    "output/*.db",
    "output/",
    ".env",
]

def check_gitignore():
    """Warn about missing .gitignore entries that protect personal data."""
    gitignore_path = ".gitignore"
    if not os.path.exists(gitignore_path):
        print(f"{C.YELLOW}[WARN] .gitignore not found!{C.END}")
        return

    with open(gitignore_path, encoding="utf-8") as f:
        content = f.read()

    missing = [entry for entry in REQUIRED_GITIGNORE_ENTRIES if entry not in content]
    if missing:
        print(f"{C.YELLOW}[WARN] .gitignore is missing these important entries:{C.END}")
        for entry in missing:
            print(f"   {C.RED}  {entry}{C.END}")
        print(f"  Run with --fix-gitignore to add them automatically.")
    else:
        print(f"{C.GREEN}[OK] .gitignore looks good.{C.END}")


def fix_gitignore():
    """Add missing protective entries to .gitignore."""
    gitignore_path = ".gitignore"
    existing = ""
    if os.path.exists(gitignore_path):
        with open(gitignore_path, encoding="utf-8") as f:
            existing = f.read()

    to_add = [e for e in REQUIRED_GITIGNORE_ENTRIES if e not in existing]
    if not to_add:
        print(f"{C.GREEN}[OK] .gitignore already contains all required entries.{C.END}")
        return

    with open(gitignore_path, "a", encoding="utf-8") as f:
        f.write("\n# --- Added by check_secrets.py ---\n")
        for entry in to_add:
            f.write(f"{entry}\n")
            print(f"  + Added: {entry}")
        print(f"{C.GREEN}✓ .gitignore updated.{C.END}")


# ============================================================
# ENTRY POINT
# ============================================================

def main():
    parser = argparse.ArgumentParser(
        description="Scan files for personal data / secrets before git commit."
    )
    parser.add_argument("--all", action="store_true",
                        help="Scan entire working tree (not just staged files)")
    parser.add_argument("--file", metavar="PATH",
                        help="Scan a single specific file")
    parser.add_argument("--install-hook", action="store_true",
                        help="Install as git pre-commit hook")
    parser.add_argument("--fix-gitignore", action="store_true",
                        help="Add missing entries to .gitignore")
    parser.add_argument("--check-gitignore", action="store_true",
                        help="Check .gitignore for missing protective entries")

    args = parser.parse_args()

    if args.install_hook:
        install_hook()
        return

    if args.fix_gitignore:
        fix_gitignore()
        return

    if args.check_gitignore:
        check_gitignore()
        return

    if args.file:
        files = [args.file]
        result = run_scan(files, staged_mode=False)
    elif args.all:
        files = get_all_tracked_files(".")
        result = run_scan(files, staged_mode=False)
    else:
        # Default: pre-commit mode — scan staged files only
        files = get_staged_files()
        if not files:
            print(f"{C.GREEN}[OK] No staged files to scan.{C.END}")
            sys.exit(0)
        result = run_scan(files, staged_mode=True)

    sys.exit(result)


if __name__ == "__main__":
    main()
