user_profile:
  # Path to your Chrome user data directory
  # Windows: "C:\\\\Users\\\\<Username>\\\\AppData\\\\Local\\\\Google\\\\Chrome\\\\User Data"
  # Linux:   "~/.config/google-chrome" or "/home/<User>/.config/google-chrome"
  # macOS:   "~/Library/Application Support/Google/Chrome"
  chrome_data_dir: "~/.config/google-chrome"
  # Chrome profile (e.g. Default or Profile 1)
  chrome_profile: "Default"
  # Path to your Lebenslauf PDF (relative to src/ or absolute)
  # Examples: "../documents/Lebenslauf_YourName.pdf"
  cv_path: "../documents/Lebenslauf_UserName.pdf"
  # Directory for additional certificates and diplomas (relative to src/ or absolute)
  documents_dir: "../documents"

defaults:
  salary_expectation: "36.000 €"
  availability: "zwei Monate nach Zusage"
  work_permit: "Germany"
  notice_period: "3 Monate zum Quartalsende"

criteria:
  min_score: 8.0
  min_salary_eur: 36000
  remote_allowed: true
  german_level: "B1"
  excluded_companies:
    - "Example Company"

gemini:
  model: "gemini-2.5-flash"
  api_keys:
    - "<YOUR_GEMINI_API_KEY_1>"
    - "<YOUR_GEMINI_API_KEY_2>"
    - "<YOUR_GEMINI_API_KEY_3>"
    - "<YOUR_GEMINI_API_KEY_4>"
    - "<YOUR_GEMINI_API_KEY_5>"

llm:
  # Priority: "local" | "openrouter" | "gemini"
  # "local" (default) — uses Ollama. Fully GDPR compliant, no data leaves your machine.
  # "openrouter" — tries OpenRouter first, Gemini fallback.
  # "gemini" — tries Google Gemini first, OpenRouter fallback.
  priority: "local"
  # Local model name (for priority: "local"). Install with: bash scripts/setup_local_llm.sh
  # Recommended: qwen2.5:7b (~4.4GB), llama3.1:8b, mistral:7b
  local_model: "qwen2.5:7b"

openrouter:
  api_key: "<YOUR_OPENROUTER_API_KEY>"   # sk-or-v1-... — also read from env OPENROUTER_API_KEY
  model: "openai/gpt-oss-120b:free"        # free model; see https://openrouter.ai/models

smtp:
  host: "smtp.gmail.com"
  port: 587
  username: "<YOUR_EMAIL>@gmail.com"
  password: "<YOUR_SMTP_PASSWORD_OR_APP_PASSWORD>"
